{
  "name": "@edisoncks/cli-loading-indicator",
  "version": "1.0.3",
  "description": "Animated CLI loading indicator using Unicode braille patterns",
  "main": "dist/index.cjs",
  "types": "index.d.ts",
  "type": "module",
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "files": [
    "dist/",
    "index.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "esbuild index.js --outfile=dist/index.mjs --format=esm --platform=node --bundle",
    "build:cjs": "esbuild index.js --outfile=dist/index.cjs --format=cjs --platform=node --bundle",
    "test": "vitest run",
    "format": "prettier --write .",
    "preversion": "npm test"
  },
  "author": "Peter Graham",
  "contributors": [
    "Edison Chong"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edisoncks/braille-pattern-cli-loading-indicator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "braille",
    "loading",
    "animated",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "chalk": "^5.0.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  }
}
